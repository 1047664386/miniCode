# miniCodeIde 云端 .env 示例 (开发用, prod 请通过 secret manager 注入)
#
# 复制成 .env: cp .env.example .env

DATABASE_URL="postgresql://mci:mci@localhost:5433/mci?schema=public"

# 切换存储后端: jsonl (默认, 桌面) / postgres (云端)
STORAGE_KIND=postgres

# Cloud server
PORT=4000
JWT_SECRET=please-change-me-in-prod
JWT_TTL_SECONDS=2592000  # 30 天

# === LLM 配置 (路线 A) ===
# 平台兜底 key (用户没配 BYOK 时走这个, 受 freeQuota 限制)
# 二选一即可: DeepSeek 性价比高、OpenAI 体验好、Anthropic 长上下文
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# 平台兜底默认 base/model (OPENAI_API_KEY 可同时跑 deepseek/moonshot/通义)
LLM_BASE_URL=https://api1.deepseek.com/v1
LLM_MODEL=deepseek-chat
# LLM_KIND=openai   # 'openai' | 'anthropic', 不填自动判断

# === 云沙箱 (路线 D / M3) ===
# mem - 本地 child_process, 零配置零费用, 不安全 (仅本地开发)
# e2b - E2B Hosted SaaS, 需要 E2B_API_KEY, 注册送 $100 一次性 credit (生产推荐)
SANDBOX_KIND=mem
# E2B_API_KEY=e2b_xxxxxx
# SANDBOX_MEM_ROOT=/tmp/mci-sandboxes  # 可选, mem 模式根目录