{
  "name": "@mini/electron",
  "version": "0.0.1",
  "private": true,
  "description": "MiniCodeIDE Electron shell",
  "main": "main.js",
  "scripts": {
    "dev": "ELECTRON_DEV=1 electron .",
    "build": "node ../../scripts/prepare-electron-resources.mjs",
    "pack": "pnpm run build && electron-builder --dir",
    "dist": "pnpm run build && electron-builder",
    "dist:mac": "pnpm run build && electron-builder --mac",
    "dist:mac:fast": "pnpm run build && CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --mac zip --arm64 && node ../../scripts/resign-mac-app.mjs",
    "dist:win": "pnpm run build && electron-builder --win",
    "dist:linux": "pnpm run build && electron-builder --linux"
  },
  "dependencies": {
    "electron-updater": "^6.3.9"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.minicodeide.app",
    "productName": "MiniCodeIDE",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "main.js",
      "preload.js",
      "agents-window.js",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "resources/server",
        "to": "server"
      },
      {
        "from": "resources/renderer",
        "to": "renderer"
      },
      {
        "from": "resources/vscode-bridge-ext",
        "to": "vscode-bridge-ext"
      },
      {
        "from": "resources/code-server/${platform}-${arch}",
        "to": "code-server",
        "filter": [
          "**/*",
          "!.cache/**"
        ]
      }
    ],
    "asar": true,
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "hardenedRuntime": true,
      "gatekeeperAssess": false
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "x64"
          ]
        }
      ],
      "category": "Development"
    },
    "publish": [
      {
        "provider": "generic",
        "url": "https://your-update-server.example.com/minicodeide/${os}"
      }
    ]
  }
}