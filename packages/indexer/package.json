{
  "name": "@mini/indexer",
  "version": "0.0.1",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "clean": "find src -type f \\( -name '*.js' -o -name '*.js.map' -o -name '*.d.ts' -o -name '*.d.ts.map' \\) -delete"
  },
  "dependencies": {
    "@mini/core": "workspace:*",
    "tree-sitter": "^0.21.1",
    "tree-sitter-typescript": "^0.23.2",
    "tree-sitter-javascript": "^0.23.1"
  },
  "devDependencies": {
    "typescript": "^5.4.5",
    "@types/node": "^20.11.0"
  }
}